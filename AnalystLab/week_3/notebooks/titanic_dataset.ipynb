   "source": [
    "#replacing NaN values in the Embarked Column (2) with the mode, since it reflects a tiny percentage of the data\n",
    "b['Embarked'] = b['Embarked'].fillna(b['Embarked'].mode()[0])\n",
    "b.drop(columns=['Cabin'], inplace = True)\n",
    "# Much faster, handles grouping automatically, and avoids the warning\n",
    "b['Age'] = b['Age'].fillna(b.groupby('Sex', observed=False)['Age'].transform('median').astype(int))\n",
    "b['Pclass'] = b['Pclass'].astype('category')\n",
    "b['Sex'] = b['Sex'].astype('category')\n",
    "b['Age'] = b['Age'].astype('int32')\n",
    "b['Embarked'] = b['Embarked'].astype('category')\n",
    "\n",
    "#Creating a FamilySize Column to determine if a person is travelling alone \n",
    "b['FamilySize'] = b['Parch'] + b['SibSp'] + 1\n",
    "b['IsAlone'] = (b['FamilySize'] == 1).astype(int)\n",
    "b[\"FareLog\"]    = np.log1p(b[\"Fare\"])\n",
    "\n",
    "\n",
    "print(f\"Shape: {b.shape}\")\n",
    "display(b.head())\n",
    "print(\"\\nMissing values:\")\n",
    "display(b.isnull().sum())\n"
   ]
