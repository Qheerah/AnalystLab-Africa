    "ax2.plot(osm, slope*np.array(osm)+intercept, \"r-\", lw=2)\n",
    "ax2.set_title(f\"Q-Q Plot: Age  (R={r:.3f})\"); axes[0,1].set_xlabel(\"Theoretical\")\n",
    "\n",
    "(osm2, osr2), (s2, i2, r2) = stats.probplot(b[\"FareLog\"], dist=\"norm\")\n",
