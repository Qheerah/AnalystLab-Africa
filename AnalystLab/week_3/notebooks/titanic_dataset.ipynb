   "source": [
    "\n",
    "\n",
    "p_survived = b['Survived'].mean()\n",
    "n = len(b['Survived'])\n",
    "print(f\"P(Survival) = {p_survived:.4f}  |  n = {n}\")\n",
    "print(f\"Expected survivors (Binomial): {stats.binom(n, p_survived).mean():.0f}  (actual: {df['Survived'].sum()})\")\n",
    "\n",
    "# Conditional probabilities\n",
    "for col in [\"Sex\",\"Pclass\"]:\n",
    "    ct = df.groupby(col)[\"Survived\"].mean().rename(\"P(Survive|group)\")\n",
    "    print(f\"\\nP(Survive | {col}):\")\n",
    "    display(ct.round(4).to_frame())\n",
    "\n",
    "# Normality tests\n",
    "print(\"\\nNormality Tests:\")\n",
    "for col in [\"Age\",\"Fare\",]:\n",
    "    sample = b[col].dropna().sample(min(500,len(df[col].dropna())), random_state=SEED)\n",
    "    stat_s, p_s = shapiro(sample)\n",
    "    stat_k, p_k = normaltest(df[col].dropna())\n",
    "    print(f\"  {col:8s}: Shapiro W={stat_s:.4f} p={p_s:.4f}  |  D'Agostino K²={stat_k:.4f} p={p_k:.4f}\")"
   ]
