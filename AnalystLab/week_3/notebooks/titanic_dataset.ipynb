    "ax3.plot(osm2, s2*np.array(osm2)+i2, \"r-\", lw=2)\n",
    "ax3.set_title(f\"Q-Q Plot: log(Fare)  (R={r2:.3f})\")\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "sns.histplot(data = b, x=survived_labels, hue = survived_labels, palette = ['green', 'orange'], ax = ax4, stat = \"probability\")\n",
    "vals = df[\"Survived\"].value_counts().sort_index()\n",
    "ax4.set_title(\"Bernoulli: P(Survive)\")\n",
    "\n",
    "\n",
    "\n",
    "pclass_surv = b.groupby(\"Pclass\", observed = False)[\"Survived\"].mean()\n",
    "sns.barplot( x = pclass_surv.index,hue = pclass_surv.index, y = pclass_surv.values, ax = ax5, palette = ['green','orange','blue'], legend = False)\n",
    "ax5.set_title(\"P(Survive | Pclass)\")\n",
    "\n",
    "\n",
    "lam = b[\"FamilySize\"].mean()\n",
    "k_vals = np.arange(0, 10)\n",
    "poisson_pmf = stats.poisson.pmf(k_vals, lam)\n",
    "\n",
    "actual_freq = (b[\"FamilySize\"].value_counts(normalize=True).reindex(k_vals, fill_value=0).values)\n",
    "plot_df = pd.DataFrame(\n",
