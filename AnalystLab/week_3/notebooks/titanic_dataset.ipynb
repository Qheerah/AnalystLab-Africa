    "ax1,ax2,ax3,ax4,ax5,ax6 = axes.flatten()\n",
    "fig.suptitle(\"Titanic – Probability Distributions\", fontsize=14, fontweight=\"bold\")\n",
    "\n",
    "\n",
    "x_age = np.linspace(b[\"Age\"].min(), b[\"Age\"].max(), 200)\n",
    "sns.histplot(data = b, x = 'Age', bins = 30, alpha = 0.6, ax = ax1, stat = \"density\", label = \"Actual\")\n",
    "ax1.plot(x_age, stats.norm.pdf(x_age, mu, sigma), \"r-\", lw = 2, label = \"Normal Fit\")\n",
    "ax1.set_title(\"Age: Normal Fit\")\n",
    "ax1.set_xlim(left=0) \n",
    "ax1.legend()\n",
    "\n",
    "(osm, osr), (slope, intercept, r) = stats.probplot(b[\"Age\"], dist=\"norm\")\n",
