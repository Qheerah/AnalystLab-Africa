    "        \"Family Size\": np.tile(k_vals, 2),\n",
    "        \"Probability\": np.concatenate([actual_freq, poisson_pmf]),\n",
    "        \"Distribution\": [\"Actual\"] * len(k_vals) + [f\"Poisson (λ={lam:.2f})\"] * len(k_vals),\n",
    "    }\n",
    ")\n",
