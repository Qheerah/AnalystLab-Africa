   "source": [
    "alpha = 0.05\n",
    "\n",
    "def report_test(name, stat, p):\n",
    "    decision = \"✅ REJECT H₀\" if p < alpha else \"❌ FAIL TO REJECT H₀\"\n",
    "    print(f\"\\n{name}\")\n",
    "    print(f\"  Statistic = {stat:.4f}  |  p-value = {p:.4f}  →  {decision}\")\n",
    "\n",
    "surv_age = b[b[\"Survived\"]==1][\"Age\"]\n",
    "died_age  = b[b[\"Survived\"]==0][\"Age\"]\n",
    "t_stat, t_p = ttest_ind(surv_age, died_age, equal_var=False)\n",
    "u_stat, u_p = mannwhitneyu(surv_age, died_age, alternative=\"two-sided\")\n",
    "report_test(\"H1: Age differs between survivors & non-survivors (Welch t-test)\", t_stat, t_p)\n",
    "report_test(\"H1 (non-parametric): Mann-Whitney U\", u_stat, u_p)\n",
    "\n",
    "ct_sex = pd.crosstab(b[\"Sex\"], b[\"Survived\"])\n",
    "chi2_sex, p_sex, dof_sex, _ = chi2_contingency(ct_sex)\n",
    "report_test(f\"H2: Sex independent of Survival (Chi² df={dof_sex})\", chi2_sex, p_sex)\n",
    "\n",
    "ct_pclass = pd.crosstab(b[\"Pclass\"], b[\"Survived\"])\n",
    "chi2_pc, p_pc, dof_pc, _ = chi2_contingency(ct_pclass)\n",
    "report_test(f\"H3: Pclass independent of Survival (Chi² df={dof_pc})\", chi2_pc, p_pc)\n",
    "\n",
    "surv_fare = b[b[\"Survived\"]==1][\"FareLog\"]\n",
    "died_fare  = b[b[\"Survived\"]==0][\"FareLog\"]\n",
    "t4, p4 = ttest_ind(surv_fare, died_fare, equal_var=False)\n",
    "report_test(\"H4: log(Fare) differs between survivors & non-survivors\", t4, p4)\n",
    "\n",
    "# Effect sizes\n",
    "pooled_std = np.sqrt((surv_age.std()**2 + died_age.std()**2) / 2)\n",
    "d_age = (surv_age.mean() - died_age.mean()) / pooled_std\n",
    "n_sex = ct_sex.values.sum()\n",
    "cramers_sex = np.sqrt(chi2_sex / (n_sex * (min(ct_sex.shape)-1)))\n",
    "print(f\"\\nEffect Sizes:\")\n",
    "print(f\"  Cohen's d (Age ~ Survival):    {d_age:.3f}  (small)\")\n",
    "print(f\"  Cramér's V (Sex ~ Survival):   {cramers_sex:.3f}  (large)\")\n"
   ]
  },
