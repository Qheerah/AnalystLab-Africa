   "source": [
    "numeric_cols = ['Pclass','Age','SibSp','SibSp','Fare', \"Parch\"]\n",
    "desc = df[numeric_cols].describe().T\n",
    "desc[\"variance\"] = df[numeric_cols].var()\n",
    "desc[\"skewness\"] = df[numeric_cols].skew()\n",
    "desc[\"kurtosis\"] = df[numeric_cols].kurtosis()\n",
    "desc[\"cv\"]       = desc[\"std\"] / desc[\"mean\"]\n",
    "display(desc.round(3))\n",
    "\n",
    "survived_labels = b['Survived'].map({0: 'No', 1:'Yes'})\n",
    "\n",
    "print(\"\\n── Age by Survival ──\")\n",
    "display(b.groupby(survived_labels, observed = False)[\"Age\"].agg([\"mean\",\"median\",\"std\",\"min\",\"max\"]).round(2))\n",
    "print(\"\\n── Fare by Pclass ──\")\n",
    "display(b.groupby(\"Pclass\", observed = False)[\"Fare\"].agg([\"mean\",\"median\",\"std\",\"min\",\"max\"]).round(2))\n"
   ]
